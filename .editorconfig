# EditorConfig: keeps whitespace consistent across IDEs so we don't waste
# review cycles on tabs-vs-spaces. https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.rs]
indent_size = 4
max_line_length = 100

[*.{yml,yaml}]
indent_size = 2

[*.md]
# Some markdown linters care about two trailing spaces; don't strip them.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{toml,lock}]
indent_size = 4
